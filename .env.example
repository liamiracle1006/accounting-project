# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agentledger
DB_USER=root
DB_PASSWORD=your_password_here
DB_ECHO=false

# ── LLM API (OpenAI-compatible) ───────────────────────────────────────────────
# 可替换为任何兼容 OpenAI 格式的服务商，如通义千问、智谱 GLM、DeepSeek 等
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1024

# ── Vision LLM API（发票 OCR，可选）──────────────────────────────────────────
# 不填则 OCR 功能不可用，其余功能正常。推荐通义千问 Qwen-VL-Max
VISION_API_KEY=
VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32chars!!
JWT_EXPIRE_HOURS=12

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agentledger
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_ECHO=false

# ── LLM API — DeepSeek（OpenAI 兼容格式）────────────────────────────────────
# DeepSeek 官网获取 API Key：https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
# 可选模型：deepseek-chat（通用对话）/ deepseek-reasoner（深度推理，更慢更贵）
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048

# ── Vision LLM API（发票 OCR，可选）──────────────────────────────────────────
# DeepSeek 暂不支持视觉模型。如需发票 OCR 功能，推荐使用通义千问 Qwen-VL。
# 不填则 OCR 功能不可用，其余所有功能正常。
# 申请阿里云 DashScope API Key：https://dashscope.aliyuncs.com
VISION_API_KEY=
VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# 生产环境必须修改为随机强密钥（≥32个字符）
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32chars!!
JWT_EXPIRE_HOURS=12

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ── RAG / Vector Store ────────────────────────────────────────────────────────
# ChromaDB 本地向量库存储路径（相对项目根目录，首次运行自动创建）
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=tax_strategies

# ── Embedding API（RAG 知识库向量化，必须单独配置）────────────────────────────
# DeepSeek 不提供 Embedding API，需要使用其他服务商。
#
# 方案 A（推荐）：阿里云 DashScope — text-embedding-v3，有免费额度
#   EMBED_API_KEY=sk-xxxx（DashScope 的 API Key，与上面 VISION_API_KEY 相同）
#   EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   EMBED_MODEL=text-embedding-v3
#
# 方案 B：OpenAI — text-embedding-3-small，按量计费
#   EMBED_API_KEY=sk-xxxx（OpenAI 的 API Key）
#   EMBED_BASE_URL=https://api.openai.com/v1
#   EMBED_MODEL=text-embedding-3-small
#
# 注意：如果不配置 Embedding，RAG 知识库功能（AI 顾问/决策卡政策检索）将不可用，
#       但核心会计功能（流水录入/凭证/报表）不受影响。
EMBED_API_KEY=
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v3
EMBED_BATCH_SIZE=32
